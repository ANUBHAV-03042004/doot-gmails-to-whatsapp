                      },
                      "sampleData": {},
                      "sourceCode": {
                        "code": "export const code = async (inputs) => {\n  const allEmails = [\n    ...(inputs.email1?.results?.messages || []).map(e => ({\n      ...e,\n      account: e.to?.text?.includes('TEXT_BY_WHICH_FORWARDED_MESSAGES_ARE_FOUND') || e.to?.value?.[0]?.address?.includes('TEXT_BY_WHICH_FORWARDED_MESSAGES_ARE_FOUND')\n        ? 'ENTER_EMAIL1_ADDRESS_IN_WHICH_FORWARD_IS_ENABLED'\n        : 'ENTER_THE_EMAIL2_ON_WHICH_YOU_HAVE_FORWARDED_THE_MAIL'\n    })),\n    ...(inputs.email2?.results?.messages || []).map(e => ({ ...e, account: 'ENTER_THE_EMAIL3' })),\n    ...(inputs.email4?.results?.messages || []).map(e => ({ ...e, account: 'ENTER_THE_EMAIL4' })),\n    ...(inputs.email5?.results?.messages || []).map(e => ({ ...e, account: 'ENTER_THE_EMAIL5' }))\n  ];\n\n  let sentIds = [];\n  try {\n    const parsed = JSON.parse(inputs.sentIds || '[]');\n    sentIds = Array.isArray(parsed) ? parsed : [];\n  } catch { sentIds = []; }\n\n  if (allEmails.length === 0) return { sent: 0, newSentIds: JSON.stringify(sentIds) };\n\n  let sentCount = 0;\n\n  for (const email of allEmails) {\n    if (sentIds.includes(String(email.id))) continue;\n\n    const from = email.from?.text || email.from?.value?.[0]?.address || 'Unknown';\n    const subject = email.subject || '(No subject)';\n    const snippet = (email.text || email.textPlain || '').toString();\n    const date = new Date(email.date).toLocaleString('en-IN', {\n      timeZone: 'Asia/Kolkata', day: '2-digit', month: 'short',\n      hour: '2-digit', minute: '2-digit'\n    });\n\n    const otpMatch = (subject + ' ' + snippet).match(/\\b(\\d{4,8})\\b/);\n    const isOtp = otpMatch && /(otp|verify|code|pin|authenticate)/i.test(subject + ' ' + snippet);\n    const otpLine = isOtp ? `\\n🔑 *OTP: ${otpMatch[1]}*` : '';\n    const emoji = isOtp ? '🔐' : '📧';\n\n    const message = `${emoji} *New Email*\\n\\n*Inbox:* ${email.account}\\n*From:* ${from}\\n*Subject:* ${subject}\\n*Time:* ${date}${otpLine}\\n\\n_${snippet.substring(0, 200)}_`;\n\n    const res = await fetch(\n      `https://api.green-api.com/waInstance${inputs.greenApiInstance}/sendMessage/${inputs.greenApiToken}`,\n      {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify({ chatId: inputs.whatsappChatId, message })\n      }\n    );\n\n    if (res.ok) {\n      sentIds.push(String(email.id));\n      sentCount++;\n    }\n  }\n\n  return {\n    sent: sentCount,\n    newSentIds: JSON.stringify(sentIds.slice(-500))\n  };\n};",
                        "packageJson": "{}"
